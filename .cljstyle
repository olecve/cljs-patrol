{:files {:ignore #{".clj-kondo"}}
 :rules {:indentation {:list-indent 1
                       :indents {defrecord [[:inner 2]]
                                 deftype [[:inner 2]]
                                 parse-handlers [[:block 1]]
                                 suggestions [[:block 1]]
                                 html-sections [[:block 1]]}}
         :functions {:enabled? false}
         :types {:enabled? false}
         :whitespace {:remove-surrounding? true
                      :remove-trailing? true
                      :insert-missing? true}
         :blank-lines {:max-consecutive 1
                       :padding-lines 1}
         :namespaces {:break-libs? true
                      :import-break-width 129}}}
